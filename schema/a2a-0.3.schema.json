{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["a2a", "fleet", "lane", "step", "op"],
  "properties": {
    "a2a": { "const": "0.3" },
    "fleet": { "type": "string" },
    "lane": { "type": "string" },
    "step": { "type": "string", "pattern": "^[A-Z0-9]+-[0-9]+$" },
    "op": { "enum": ["shell", "write", "edit", "probe", "precheck", "notion"] },
    "cmd": { "type": "string" },
    "file": { "type": "string" },
    "desc": { "type": "string" },
    "depends_on": { "type": "string" },
    "gate": { "type": "string" },
    "halt_on_fail": { "type": "boolean" }
  }
}
